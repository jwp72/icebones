{
  "name": "@icebones/pixi",
  "version": "0.1.0",
  "description": "PixiJS 8 renderer for IceBones skeletal animation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@icebones/core": "*"
  },
  "peerDependencies": {
    "pixi.js": "^8.16.0"
  },
  "devDependencies": {
    "pixi.js": "^8.17.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
