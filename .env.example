# Required: Voyage AI API key for embeddings
VOYAGE_API_KEY=pa-...

# Required for chat endpoint: at least one LLM provider key
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM provider: "claude", "openai", or "openrouter"
LLM_PROVIDER=claude

# OpenRouter (alternative LLM provider)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Database (port 5433 to avoid conflict with HockeyQuest on 5432)
DATABASE_URL=postgresql://icebones:icebones@localhost:5433/icebones
